# =============================================================================
# .env.example — Variables d'environnement pour le déploiement
#
# Copier ce fichier : cp deploy/.env.example .env
# Ne jamais committer le fichier .env (il est dans .gitignore).
# =============================================================================

# ── Serveur Node.js ──────────────────────────────────────────────────────────
# Port d'écoute Express (mettre un reverse-proxy Nginx/Caddy devant sur le 80/443)
PORT=3000

# Environnement Node
NODE_ENV=production

# ── Frontend (optionnel) ─────────────────────────────────────────────────────
# Chemin absolu vers le dossier buildé du frontend.
# Laisser vide = chemin relatif automatique depuis dist/index.mjs.
# FRONTEND_DIST=/opt/mpanolontsaina/artifacts/mpanolontsaina-ia/dist/public

# ── URL du backend externe ───────────────────────────────────────────────────
# URL de base de l'API Mpanolontsaina (sans slash final).
# Utilisée par le proxy Express côté serveur (/api/ext-api/*)
# ET par le proxy Vite en développement (/ext-api/*).
# Changer cette valeur suffit pour pointer vers un autre environnement
# (staging, instance locale, etc.).
EXTERNAL_API_URL=https://api.mpanolontsaina-ia.duckdns.org
